#!/bin/bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SCHEME="Wilson"
CONFIG="${1:-Debug}"

echo "Building Wilson ($CONFIG)..."
xcodebuild build \
  -project "$PROJECT_DIR/Wilson.xcodeproj" \
  -scheme "$SCHEME" \
  -configuration "$CONFIG" \
  -destination "platform=macOS,arch=arm64" \
  -quiet

APP_PATH=$(find ~/Library/Developer/Xcode/DerivedData/Wilson-*/Build/Products/"$CONFIG" -name "Wilson.app" -maxdepth 1 2>/dev/null | head -1)

if [ -z "$APP_PATH" ]; then
  echo "Error: Could not find built app" >&2
  exit 1
fi

echo "Launching $APP_PATH"
open "$APP_PATH"
